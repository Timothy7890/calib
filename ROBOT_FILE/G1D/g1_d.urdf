  <link name="right_dex1_base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.02"/>
      </geometry>
      <material name="dex1_base_gray">
        <color rgba="0.6 0.6 0.6 1"/>
      </material>
    </visual>
  </link>

  <!-- 第一个串联固定关节：沿杆方向 +X 移动 155mm，坐标轴方向不变 -->
  <joint name="right_dex1_fixed_joint_1" type="fixed">
    <origin xyz="0.155 0 0" rpy="0 0 0"/>
    <parent link="right_dex1_base_link"/>
    <child link="right_dex1_link_155"/>
  </joint>

  <link name="right_dex1_link_155">
    <inertial>
      <origin xyz="-0.0775 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>

    <!-- 可视化：一根沿 X 方向的简化杆，长度 155mm -->
    <visual>
      <origin xyz="-0.0775 0 0" rpy="0 1.57079632679 0"/>
      <geometry>
        <cylinder radius="0.006" length="0.155"/>
      </geometry>
      <material name="dex1_rod_gray">
        <color rgba="0.4 0.4 0.4 1"/>
      </material>
    </visual>
  </link>

  <!--
    第二个串联固定关节：
    绕 Y 轴转 +45°，再沿旋转后的自身 +X 方向移动 52mm。

    因为 URDF joint origin 的 xyz 是写在 parent frame 下，
    若先旋转 Ry(+45°)，再沿 child/local +X 走 0.052m，
    则 parent frame 下的位移为：

      x = 0.052 * cos(45°) = 0.03676955
      y = 0
      z = -0.052 * sin(45°) = -0.03676955

    URDF rpy 中绕 Y 轴为 pitch，因此 rpy="0 0.78539816339 0"。
  -->
  <joint name="right_dex1_fixed_joint_2" type="fixed">
    <origin xyz="0.03676955 0 -0.03676955" rpy="0 0.78539816339 0"/>
    <parent link="right_dex1_link_155"/>
    <child link="right_dex1_tool_link"/>
  </joint>

  <link name="right_dex1_tool_link">
    <inertial>
      <origin xyz="-0.026 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>

    <!-- 可视化：第二段 52mm 简化杆，沿该 link 自身 X 方向 -->
    <visual>
      <origin xyz="-0.026 0 0" rpy="0 1.57079632679 0"/>
      <geometry>
        <cylinder radius="0.005" length="0.052"/>
      </geometry>
      <material name="dex1_tool_light">
        <color rgba="0.8 0.8 0.8 1"/>
      </material>
    </visual>
  </link>

</robot>